{
  "name": "@ank1015/llm-types",
  "version": "0.0.1",
  "description": "Type definitions for LLM SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "llm",
    "types",
    "typescript"
  ],
  "license": "MIT"
}
