{
  "name": "@ank1015/llm-server",
  "version": "0.0.3",
  "private": true,
  "description": "Private Node-only Hono orchestration server for projects, artifact directories, agent sessions, and installable skills",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist coverage *.tsbuildinfo && tsc",
    "dev": "sh -c 'tsc && tsc --watch --preserveWatchOutput & TSC_PID=$!; trap \"kill $TSC_PID\" EXIT; node --watch dist/server.js'",
    "start": "node dist/server.js",
    "test-skill": "pnpm run build && node dist/test-skill.js",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:live": "vitest run tests/live",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests vitest.config.ts",
    "clean": "rm -rf dist coverage *.tsbuildinfo"
  },
  "keywords": [
    "llm",
    "server",
    "hono",
    "agents",
    "sessions",
    "skills",
    "typescript",
    "node"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ank1015/llm.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/ank1015/llm/tree/main/packages/server",
  "bugs": {
    "url": "https://github.com/ank1015/llm/issues"
  },
  "dependencies": {
    "@ank1015/llm-agents": "workspace:^",
    "@ank1015/llm-core": "workspace:^",
    "@ank1015/llm-sdk": "workspace:^",
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@hono/node-server": "^1.14.1",
    "@sinclair/typebox": "^0.34.48",
    "hono": "^4.7.6",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  }
}
