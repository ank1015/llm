{
  "name": "@ank1015/llm-server",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "sh -c 'tsc && tsc --watch --preserveWatchOutput & TSC_PID=$!; trap \"kill $TSC_PID\" EXIT; node --watch dist/server.js'",
    "start": "node dist/server.js",
    "test": "vitest run --exclude tests/integration/**",
    "test:watch": "vitest --exclude tests/integration/**",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ank1015/llm-agents": "workspace:^",
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@ank1015/llm-extension": "workspace:^",
    "@ank1015/llm-research": "workspace:^",
    "@ank1015/llm-sdk": "workspace:^",
    "@ank1015/llm-sdk-adapters": "workspace:^",
    "@hono/node-server": "^1.14.1",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.7.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.2.3",
    "vitest": "^2.1.0"
  }
}
