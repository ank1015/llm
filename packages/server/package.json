{
  "name": "@ank1015/llm-server",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ank1015/llm-research": "workspace:^",
    "@hono/node-server": "^1.14.1",
    "hono": "^4.7.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "vitest": "^2.1.0"
  }
}
