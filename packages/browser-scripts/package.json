{
  "name": "@ank1015/llm-browser-scripts",
  "version": "0.0.1",
  "description": "Browser-focused scripts for the LLM SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "llm",
    "browser",
    "scripts"
  ],
  "license": "MIT",
  "dependencies": {
    "@ank1015/llm-extension": "workspace:^"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
