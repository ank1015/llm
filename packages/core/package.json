{
  "name": "@ank1015/llm-core",
  "version": "0.0.1",
  "description": "Core SDK for LLM interactions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  },
  "keywords": [
    "llm",
    "sdk",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@ank1015/llm-types": "workspace:^",
    "@anthropic-ai/sdk": "^0.72.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "openai": "^6.17.0",
    "partial-json": "^0.1.7"
  }
}
