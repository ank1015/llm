{
  "name": "@ank1015/llm-core",
  "version": "0.0.2",
  "description": "Stateless multi-provider LLM runtime with normalized streaming events and preserved native responses",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist *.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "node ./scripts/run-integration-tests.mjs",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests scripts vitest.config.ts vitest.setup.ts",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  },
  "keywords": [
    "llm",
    "sdk",
    "ai",
    "openai",
    "anthropic",
    "google",
    "streaming",
    "agents",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ank1015/llm.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ank1015/llm/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/ank1015/llm/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ank1015/llm-types": "workspace:^",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.44.0",
    "@sinclair/typebox": "^0.34.48",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "openai": "^6.27.0",
    "partial-json": "^0.1.7",
    "uuid": "^13.0.0"
  }
}
