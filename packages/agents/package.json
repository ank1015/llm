{
  "name": "@ank1015/llm-agents",
  "version": "0.0.7",
  "description": "Node-only general-purpose agent toolkit with bundled skills and helper-backed workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist coverage *.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "agent:cli": "tsx src/cli/agent-cli.ts",
    "skill:tester": "tsx src/cli/skill-tester.ts",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests vitest.config.ts",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "prepack": "pnpm run build",
    "prepublishOnly": "node ../../scripts/ensure-pnpm-publish.mjs"
  },
  "keywords": [
    "llm",
    "agents",
    "ai",
    "node",
    "tools",
    "skills",
    "typescript",
    "images"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ank1015/llm.git",
    "directory": "packages/agents"
  },
  "homepage": "https://github.com/ank1015/llm/tree/main/packages/agents",
  "bugs": {
    "url": "https://github.com/ank1015/llm/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ank1015/llm-extension": "workspace:^",
    "@ank1015/llm-sdk": "workspace:^",
    "@ank1015/llm-sdk-adapters": "workspace:^",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "@sinclair/typebox": "^0.34.48",
    "chalk": "^5.6.2",
    "diff": "^8.0.3",
    "file-type": "^21.3.0",
    "glob": "^13.0.6",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "@types/node": "^25.3.2",
    "vitest": "^2.1.0"
  }
}
