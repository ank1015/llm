{
  "name": "@ank1015/llm-sdk",
  "version": "0.0.3",
  "description": "Opinionated SDK layer over @ank1015/llm-core with credential resolution, conversations, and session helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./keys": {
      "types": "./dist/keys.d.ts",
      "import": "./dist/keys.js"
    },
    "./llm": {
      "types": "./dist/llm.d.ts",
      "import": "./dist/llm.js"
    },
    "./messages": {
      "types": "./dist/messages.d.ts",
      "import": "./dist/messages.js"
    },
    "./model-input": {
      "types": "./dist/model-input.d.ts",
      "import": "./dist/model-input.js"
    },
    "./response": {
      "types": "./dist/response.d.ts",
      "import": "./dist/response.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    },
    "./tool": {
      "types": "./dist/tool.d.ts",
      "import": "./dist/tool.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ../../scripts/remove-paths.mjs dist --tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run tests/unit --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests vitest.config.ts",
    "release:check": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test:unit && pnpm run test:coverage",
    "clean": "node ../../scripts/remove-paths.mjs dist coverage --tsbuildinfo",
    "prepack": "pnpm run release:check",
    "prepublishOnly": "node ../../scripts/ensure-pnpm-publish.mjs"
  },
  "keywords": [
    "llm",
    "sdk",
    "ai",
    "agents",
    "conversations",
    "sessions",
    "adapters",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ank1015/llm.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/ank1015/llm/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/ank1015/llm/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@ank1015/llm-core": "workspace:^",
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  }
}
