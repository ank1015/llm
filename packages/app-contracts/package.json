{
  "name": "@ank1015/llm-app-contracts",
  "version": "0.0.1",
  "description": "Shared HTTP DTOs and TypeBox schemas for @ank1015/llm server and app clients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "rm -rf dist coverage *.tsbuildinfo && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests",
    "test:coverage": "vitest run tests --coverage",
    "lint": "eslint src tests vitest.config.ts",
    "clean": "rm -rf dist coverage *.tsbuildinfo"
  },
  "keywords": [
    "llm",
    "contracts",
    "server",
    "http",
    "dto",
    "typebox",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ank1015/llm.git",
    "directory": "packages/app-contracts"
  },
  "homepage": "https://github.com/ank1015/llm/tree/main/packages/app-contracts",
  "bugs": {
    "url": "https://github.com/ank1015/llm/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ank1015/llm-types": "workspace:^",
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  }
}
