{
  "manifest_version": 3,
  "name": "LLM Extension",
  "version": "0.0.1",
  "description": "Chrome extension with general-purpose native messaging RPC",
  "permissions": ["nativeMessaging", "scripting", "activeTab", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
