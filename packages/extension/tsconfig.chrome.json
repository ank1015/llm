{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": ["chrome"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true
