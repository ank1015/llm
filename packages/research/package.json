{
  "name": "@ank1015/llm-research",
  "version": "0.0.1",
  "description": "Research utilities for LLM SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "llm",
    "research",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
