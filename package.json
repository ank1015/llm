{
  "name": "@ank1015/llm",
  "version": "0.0.1",
  "private": true,
  "description": "LLM SDK monorepo",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@ank1015/llm-core --filter=@ank1015/llm-sdk --filter=@ank1015/llm-agents --filter=@ank1015/llm-server",
    "dev": "turbo run dev",
    "dev:web-app": "pnpm --filter @ank1015/llm-web-app dev",
    "start:web-app": "pnpm --filter @ank1015/llm-web-app start",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "typecheck": "turbo run typecheck",
    "lint": "eslint apps packages scripts eslint.config.js lint-staged.config.js",
    "lint:fix": "eslint apps packages scripts eslint.config.js lint-staged.config.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
