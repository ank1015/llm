{
  "name": "@ank1015/llm",
  "version": "0.0.1",
  "private": true,
  "description": "LLM SDK monorepo",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@ank1015/llm-types --filter=@ank1015/llm-core --filter=@ank1015/llm-sdk --filter=@ank1015/llm-server",
    "dev": "turbo run dev",
    "dev:server": "pnpm --filter @ank1015/llm-server dev",
    "dev:dashboard": "pnpm --filter @ank1015/llm-usage-dashboard dev",
    "start:server": "pnpm --filter @ank1015/llm-server start",
    "start:dashboard": "pnpm --filter @ank1015/llm-usage-dashboard start",
    "test": "turbo run test",
    "test:unit": "turbo run test -- tests/unit",
    "test:integration": "turbo run test -- tests/integration",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
